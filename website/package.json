{
  "name": "smart-grind-website",
  "version": "1.0.0",
  "description": "Smart Grind - Pattern Practice Web App with spaced repetition for mastering coding interviews",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:bundle": "node scripts/create-offline-bundle.js",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.ts\" \"e2e/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"e2e/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "./node_modules/.bin/playwright test",
    "test:e2e:ui": "./node_modules/.bin/playwright test --ui",
    "test:e2e:debug": "./node_modules/.bin/playwright test --debug",
    "test:e2e:headed": "./node_modules/.bin/playwright test --headed",
    "test:e2e:chrome": "./node_modules/.bin/playwright test --project=chromium",
    "test:e2e:firefox": "TEST_ALL_BROWSERS=true playwright test --project=firefox",
    "test:e2e:webkit": "TEST_ALL_BROWSERS=true playwright test --project=webkit",
    "test:e2e:mobile": "TEST_ALL_BROWSERS=true playwright test --project=mobile-chrome",
    "test:e2e:report": "./node_modules/.bin/playwright show-report",
    "test:all": "npm run test && npm run test:e2e",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "leetcode",
    "algorithms",
    "coding-interviews",
    "spaced-repetition",
    "pattern-practice",
    "study-tracker",
    "pwa",
    "typescript",
    "cloudflare-workers"
  ],
  "author": "AlgoVyn Team",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlgoVyn/smart-grind.git",
    "directory": "website"
  },
  "bugs": {
    "url": "https://github.com/AlgoVyn/smart-grind/issues"
  },
  "homepage": "https://algovyn.com/smartgrind",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.4.0",
    "http-server": "^14.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "wrangler": "^4.61.0"
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "jose": "^5.2.0"
  }
}
